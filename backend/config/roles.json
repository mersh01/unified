  "workflow_permissions": {
    "SUBMITTED": {
      "allowed_permissions": [
        "assign_to_screener",
        "process_submission"
      ],
      "allowed_actions": [
        "ASSIGN_TO_SCREENER",
        "REJECT"
      ]
    },
    "PRESCREEN": {
      "allowed_permissions": [
        "screen_application"
      ],
      "allowed_actions": [
        "PASS_TO_DESK",
        "PASS_TO_INSPECT",
        "REJECT",
        "REQUEST_INFO"
      ]
    },
    "DESK_REVIEW": {
      "allowed_permissions": [
        "review_application"
      ],
      "allowed_actions": [
        "APPROVE",
        "PASS_TO_INSPECT",
        "REJECT",
        "REQUEST_INFO"
      ]
    },
    "INSPECTION": {
      "allowed_permissions": [
        "conduct_inspection"
      ],
      "allowed_actions": [
        "FAIL_INSPECTION",
        "PASS_INSPECTION"
      ]
    },
    "BOH_REVIEW": {
      "allowed_permissions": [
        "approve_application"
      ],
      "allowed_actions": [
        "APPROVE",
        "REJECT",
        "REQUEST_INFO"
      ]
    },
    "APPROVED": {
      "allowed_permissions": [
        "issue_certificate"
      ],
      "allowed_actions": [
        "ISSUE_CERTIFICATE"
      ]
    },
    "ISSUED": {
      "allowed_permissions": [],
      "allowed_actions": []
    },
    "RETURNED": {
      "allowed_permissions": [
        "create_application"
      ],
      "allowed_actions": [
        "RESUBMIT"
      ]
    },
    "REJECTED": {
      "allowed_permissions": [],
      "allowed_actions": []
    },
    "REVIEW": {
      "allowed_permissions": [
        "review_application"
      ],
      "allowed_actions": [
        "REQUEST_INFO",
        "SEND_TO_BOH"
      ]
    },
    "BOH_APPROVAL": {
      "allowed_permissions": [
        "approve_application"
      ],
      "allowed_actions": [
        "APPROVE",
        "REJECT"
      ]
    }
  },
