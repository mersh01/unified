          "id": "license_info",
          "order": 1,
          "step_key": "step_1_license_info",
          "icon": "\ud83d\ude97",
          "fields": [
            {
              "name": "full_name",
              "type": "text",
              "required": true
            },
            {
              "name": "license_number",
              "type": "text",
              "required": true
            },
            {
              "name": "date_of_birth",
              "type": "date",
              "required": true
            },
            {
              "name": "expiry_date",
              "type": "date",
              "required": true
            },
            {
              "name": "blood_group",
              "type": "select",
              "required": true,
              "options": [
                "A+",
                "A-",
                "B+",
                "B-",
                "O+",
                "O-",
                "AB+",
                "AB-"
              ]
            }
          ]
        },
        {
          "id": "medical_test",
          "order": 2,
          "step_key": "step_2_medical_test",
          "icon": "\ud83c\udfe5",
          "type": "verification",
          "verification_required": true,
          "fields": [
            {
              "name": "medical_certificate",
              "type": "file",
              "required": true,
              "accepted_formats": [
                "pdf",
                "jpg",
                "png"
              ],
              "max_size_mb": 5
            },
            {
              "name": "medical_center_name",
              "type": "text",
              "required": true
            },
            {
              "name": "doctor_name",
              "type": "text",
              "required": true
            },
            {
              "name": "test_date",
              "type": "date",
              "required": true
            }
          ]
        },
        {
          "id": "document_upload",
          "order": 3,
          "step_key": "step_3_document_upload",
          "icon": "\ud83d\udcce",
          "type": "verification",
          "verification_required": true,
          "fields": [
            {
              "name": "old_license_copy",
              "type": "file",
              "required": true,
              "accepted_formats": [
                "pdf",
                "jpg",
                "png"
              ],
              "max_size_mb": 5
            },
            {
              "name": "photograph",
              "type": "file",
              "required": true,
              "accepted_formats": [
                "jpg",
                "png"
              ],
              "max_size_mb": 2
            },
            {
              "name": "address_proof",
              "type": "file",
              "required": true,
              "accepted_formats": [
                "pdf",
                "jpg",
                "png"
              ],
              "max_size_mb": 5
            }
          ]
        },
        {
          "id": "verification",
          "order": 4,
          "step_key": "step_4_verification",
          "icon": "\u2705",
          "type": "verification",
          "final_step": true,
          "fields": [
            {
              "name": "declaration",
